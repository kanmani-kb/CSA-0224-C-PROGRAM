#include <stdio.h>
#include <string.h>

int palindrome(char *str)
{
    char *start = str;
    char *end = str + strlen(str) - 1;

    while (start < end)
    {
        if (*start != *end)
            return 0;   // Not palindrome

        start++;
        end--;
    }

    return 1;   // Palindrome
}

int main()
{
    char str[100];

    printf("Enter a string: ");
    scanf("%s", str);

    if (palindrome(str))
        printf("Palindrome");
    else
        printf("Not Palindrome");

    return 0;
}
