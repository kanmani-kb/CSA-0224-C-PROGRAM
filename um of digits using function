#include <stdio.h>

int sumdigits(int n)
{
    int sum = 0;
    while(n > 0)
    {
        sum = sum + (n % 10);
        n = n / 10;
    }
    return sum;
}

int main()
{
    int num, result;
    
    printf("Enter a number: ");
    scanf("%d", &num);
    
    result = sumdigits(num);
    
    printf("Sum of digits = %d", result);
    
    return 0;
}
