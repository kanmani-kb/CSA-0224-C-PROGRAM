#include <stdio.h>

int checkEqual(int a, int b)
{
    if(a == b)
        return 1;
    else
        return 0;
}

int main()
{
    int num1, num2;

    printf("Enter first number: ");
    scanf("%d", &num1);

    printf("Enter second number: ");
    scanf("%d", &num2);

    if(checkEqual(num1, num2))
        printf("Both numbers are equal.\n");
    else
        printf("Both numbers are not equal.\n");

    return 0;
}
