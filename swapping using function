#include <stdio.h>

int findmax(int a[], int n)
{
    int i, max;
    max = a[0];
    
    for(i = 1; i < n; i++)
    {
        if(a[i] > max)
            max = a[i];
    }
    
    return max;
}

int main()
{
    int a[10], n, i, max;
    
    printf("Enter number of elements: ");
    scanf("%d", &n);
    
    printf("Enter elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);
    
    max = findmax(a, n);
    
    printf("Maximum number = %d", max);
    
    return 0;
}
