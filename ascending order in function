#include<stdio.h>
int sortas(int arr[]);
int main(){
    int arr[5]={9,6,5,8,4};
    int sort;
    sort=sortas(arr);
    return 0;
}
int sortas(int arr[]){
    int i,j,temp,sort;
    for(i=0;i<5;i++){
        for(j=0;j<5-i-1;j++){
            if(arr[j]>arr[j+1]){
                temp=arr[j];
                arr[j]=arr[j+1];
                arr[j+1]=temp;
            }
        }
    }
    printf("array in ascending order:\n");
    for(i=0;i<5;i++){
        printf(" %d",arr[i]);
    }
    return sort;
}
