#include <stdio.h>

int count(int arr[], int n, int target)
{
    if (target == 0)
        return 1;

    if (n == 0)
        return 0;

    return count(arr, n-1, target - arr[n-1]) +
           count(arr, n-1, target);
}

int main()
{
    int arr[] = {1, 2, 3};
    int n = 3;
    int target = 3;

    printf("Number of subsets = %d", count(arr, n, target));

    return 0;
}
