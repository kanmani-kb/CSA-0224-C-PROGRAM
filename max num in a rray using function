#include<stdio.h>
int maxarray(int arr[]);
int main(){
    int max;
    int arr[5]={54,80,21,81,64};
    max=maxarray(arr);
    return 0;
}
int maxarray(int arr[]){
    int i,max;
    for(i=0;i<5;i++){
        if(arr[i]>max)
        max=arr[i];
         
    }
    printf("the maximum element is %d",max);
    return max;
}
