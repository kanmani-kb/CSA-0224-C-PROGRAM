#include<stdio.h>
void multiply(int a[10][10],int b[10][10],int r1,int c1,int c2){
    int result[10][10];
    int i,j,k;
    
    for(i=0;i<r1;i++){
        for(j=0;j<c2;j++){
            result[i][j]=0;
            for(k=0;k<c1;k++){
                result[i][j]+=a[i][k]*b[k][j];
            }
        }
    }
    
    printf("resultant matrix:\n");
    for(i=0;i<r1;i++){
        for(j=0;j<c2;j++){
            printf(" %d",result[i][j]);
        }
        printf("\n");
    }
}
int main(){
    int a[10][10],b[10][10];
    int r1,r2,c1,c2;
    int i,j;
    scanf("%d%d",&r1,&c1);
    scanf("%d%d",&r2,&c2);
    for(i=0;i<r1;i++){
        for(j=0;j<c1;j++){
            scanf("%d",&a[i][j]);
        }
    }
    for(i=0;i<r2;i++){
        for(j=0;j<c2;j++){
            scanf(" %d",&b[i][j]);
        }
    }
    multiply(a,b,r1,c1,c2);
    return 0;
}
