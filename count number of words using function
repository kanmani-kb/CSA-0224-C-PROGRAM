#include <stdio.h>

int countWords(char str[])
{
    int i = 0, count = 0;

    while(str[i] != '\0')
    {
        // Check for space followed by character
        if(str[i] == ' ' && str[i+1] != ' ' && str[i+1] != '\0')
            count++;

        i++;
    }

    return count + 1;   // Add 1 for first word
}

int main()
{
    char str[100];

    printf("Enter a sentence: ");
    fgets(str, sizeof(str), stdin);

    printf("Number of words = %d", countWords(str));

    return 0;
}
