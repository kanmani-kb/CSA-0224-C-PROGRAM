#include <stdio.h>
#include <string.h>

void reverseWord(char str[])
{
    int start = 0, end, i;

    for(i = 0; i <= strlen(str); i++)
    {
        if(str[i] == ' ' || str[i] == '\0')
        {
            end = i - 1;

            while(start < end)
            {
                char temp = str[start];
                str[start] = str[end];
                str[end] = temp;
                start++;
                end--;
            }

            start = i + 1;
        }
    }
}

int main()
{
    char str[100];

    printf("Enter a sentence: ");
    fgets(str, sizeof(str), stdin);

    reverseWord(str);

    printf("After reversing words:\n%s", str);

    return 0;
}
