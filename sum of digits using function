#include <stdio.h>

int sum(int n)
{
    int s = 0;
    while(n != 0)
    {
        s = s + n % 10;
        n = n / 10;
    }
    return s;
}

int main()
{
    int num, result;
    
    printf("Enter a number: ");
    scanf("%d", &num);
    
    result = sum(num);
    
    printf("Sum of digits = %d", result);
    
    return 0;
}
